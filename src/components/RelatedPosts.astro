---
/**
 * RelatedPosts — displays 3-4 related articles from the same category.
 */
import type { WPPostSummary } from "../lib/wordpress";
import ArticleCard from "./ArticleCard.astro";

interface Props {
  posts: WPPostSummary[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="mt-12 border-t border-brand-200 pt-8">
    <h2 class="mb-6 text-xl font-bold text-brand-900">Articles similaires</h2>
    <div class="grid gap-8 sm:grid-cols-2">
      {posts.map((post) => (
        <ArticleCard post={post} />
      ))}
    </div>
  </section>
)}
