---
/**
 * Breadcrumbs — semantic nav + JSON-LD structured data.
 * JSON-LD is injected via BaseHead; this component renders the visible breadcrumb.
 */
interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Fil d'ariane" class="mb-6 text-sm text-brand-500">
  <ol class="flex flex-wrap items-center gap-1" role="list">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span aria-hidden="true" class="text-brand-300">/</span>}
        {item.url ? (
          <a href={item.url} class="hover:text-brand-700 transition-colors">
            {item.name}
          </a>
        ) : (
          <span class="text-brand-700" aria-current="page">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
